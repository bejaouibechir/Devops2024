# ============================================================
# Configuration Nginx - StockMaster
# Géré par Ansible - ne pas modifier manuellement
# Chemin standard: /etc/nginx/sites-available/stockmaster
# ou /etc/nginx/conf.d/stockmaster.conf
# ============================================================

# ============================================================
# Upstream - Serveurs Tomcat Backend
# ============================================================
# Load balancing vers les serveurs Tomcat du groupe 'backend'
upstream backend_pool {
    # Stratégie least_conn : envoie les requêtes vers le serveur
    # ayant le moins de connexions actives
    least_conn;

{% for backend_host in groups['backend'] %}
    server {{ hostvars[backend_host]['ansible_host'] }}:{{ tomcat_port }};
{% endfor %}

    # Keepalive connections
    keepalive 32;
}

# ============================================================
# Virtual Host HTTP - Port 80
# ============================================================
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name _;
    client_max_body_size 50M;

    # Logs
    access_log /var/log/nginx/stockmaster-access.log;
    error_log /var/log/nginx/stockmaster-error.log;

    # ============================================================
    # Frontend - Application React
    # ============================================================
    location / {
        # Racine des fichiers statiques (React build)
        root {{ frontend_deploy_root }};

        # Try fichier, puis répertoire, sinon index.html (SPA)
        try_files $uri $uri/ /index.html;

        # Headers pour cache et sécurité
        add_header Cache-Control "public, max-age=3600";
        add_header X-Content-Type-Options "nosniff" always;
    }

    # ============================================================
    # API Backend - Spring Boot REST API
    # ============================================================
    location /stockmaster/api/ {
        # Proxy vers le pool Tomcat
        proxy_pass http://backend_pool;

        # Headers proxy essentiels
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;

        # Temps d'attente
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Keepalive vers upstream
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }

    # ============================================================
    # Swagger UI - Documentation API
    # ============================================================
    location /stockmaster/swagger-ui/ {
        # Proxy vers le pool Tomcat
        proxy_pass http://backend_pool;

        # Headers proxy
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Cache Swagger resources
        add_header Cache-Control "public, max-age=86400";
    }

    # ============================================================
    # Health check endpoint (optionnel)
    # ============================================================
    location /health {
        proxy_pass http://backend_pool;
        proxy_set_header Host $host;
        access_log off;
    }

    # ============================================================
    # Sécurité - Refuser accès administratif
    # ============================================================
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ /\.git {
        deny all;
        access_log off;
        log_not_found off;
    }

}

