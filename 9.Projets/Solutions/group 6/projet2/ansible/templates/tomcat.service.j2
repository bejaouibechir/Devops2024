# ============================================================
# Systemd Service - Tomcat 10.1
# Géré par Ansible - ne pas modifier manuellement
# Chemin standard: /etc/systemd/system/tomcat.service
# ============================================================

[Unit]
Description=Apache Tomcat 10.1 Web Application Server - StockMaster
After=network.target

[Service]
Type=forking
User={{ tomcat_user }}
Group={{ tomcat_group }}

Environment="CATALINA_HOME={{ tomcat_home }}"
Environment="CATALINA_BASE={{ tomcat_home }}"
Environment="CATALINA_PID={{ tomcat_home }}/temp/tomcat.pid"
Environment="JAVA_HOME=/usr/lib/jvm/java-{{ java_version }}-openjdk-amd64"

# Script d'environnement pour les variables Spring Boot
EnvironmentFile={{ tomcat_home }}/bin/setenv.sh

ExecStart={{ tomcat_home }}/bin/startup.sh
ExecStop={{ tomcat_home }}/bin/shutdown.sh

# Redémarrage automatique
Restart=always
RestartSec=10

# Timeouts
StartupType=forking
TimeoutStartSec=120
TimeoutStopSec=30

# Logs
StandardOutput=journal
StandardError=journal

# Sécurité
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
